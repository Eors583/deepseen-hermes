# Copy this file to .env.prod before deployment.
#
# Production web bind for the hermes-web Nginx container. Use 127.0.0.1
# behind a reverse proxy on the same host, or 0.0.0.0 when your firewall /
# load balancer terminates public traffic. The FastAPI backend stays internal
# on the Docker network.
HERMES_WEB_BIND=0.0.0.0
HERMES_WEB_PORT=9119

# Auth is shared with DeepSeen by default. Herbound reads DeepSeen's "User"
# table for login and stores Herbound-only data in herbound_* tables.
HERBOUND_AUTH_PROVIDER=deepseen

# Must be exactly the same JWT_SECRET used by the DeepSeen backend. Herbound
# uses it to issue and verify DeepSeen-compatible login tokens.
JWT_SECRET=

# PostgreSQL is the production data store. In the shared deployment, point
# HERMES_DATABASE_URL / DATABASE_URL at the DeepSeen PostgreSQL database.
# The POSTGRES_* values below are only used if you explicitly start the
# optional standalone-db profile for a separate Herbound database.
POSTGRES_DB=hermes
POSTGRES_USER=hermes
POSTGRES_PASSWORD=change-me-before-prod
POSTGRES_BIND=127.0.0.1
POSTGRES_PORT=5432

# Use your DeepSeen database URL here. For example, when Herbound and
# DeepSeen share the same Docker network:
# HERMES_DATABASE_URL=postgresql://postgres:postgres@viralforge-postgres:5432/viralforge
# DATABASE_URL=postgresql://postgres:postgres@viralforge-postgres:5432/viralforge
HERMES_DATABASE_URL=
DATABASE_URL=

# DeepSeen SDK endpoint. Users enter their DeepSeen API Key in the Web UI
# settings page; the key is stored in PostgreSQL.
DEEPSEEN_BASE_URL=https://deepseen.ai/v1

# Model/provider secrets. Copy the values from your project-local .hermes/.env
# for production deployment. DeepSeen API Key should stay user-managed in UI
# unless you are testing a single shared key.
OPENAI_API_KEY=
CUSTOM_API_KEY=
OMINILINK_API_KEY=
AIG_AI_API_KEY=
GOOGLE_AI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
OPENAI_BASE_URL=https://api.ominilink.ai/v1
CUSTOM_BASE_URL=https://api.ominilink.ai/v1
GOOGLE_AI_BASE_URL=https://api.ominilink.ai
GEMINI_BASE_URL=https://api.ominilink.ai
