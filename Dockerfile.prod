FROM node:24-bookworm-slim AS frontend

WORKDIR /app

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      g++ \
      make \
      pkg-config \
      python3 && \
    rm -rf /var/lib/apt/lists/*

COPY package.json package-lock.json ./
COPY hermes-web-ui/package.json hermes-web-ui/package.json
COPY hermes-web-ui/package-lock.json hermes-web-ui/package-lock.json
RUN npm install --no-audit --ignore-scripts && \
    cd hermes-web-ui && npm install --no-audit --ignore-scripts

COPY hermes-web-ui/ hermes-web-ui/
RUN cd hermes-web-ui && npm run build


FROM python:3.12-slim-bookworm AS runtime

ENV PYTHONUNBUFFERED=1
ENV HERMES_HOME=/opt/data
ENV HERMES_WEB_DIST=/app/hermes_cli/web_dist
ENV HERMES_ENABLE_PROJECT_PLUGINS=1
ENV HERMES_WEB_PASSWORD_AUTH=1
ENV PATH="/app/.venv/bin:/usr/local/bin:${PATH}"

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      ffmpeg \
      git \
      openssh-client \
      procps \
      ripgrep \
      build-essential \
      python3-dev \
      libffi-dev \
      libolm-dev && \
    rm -rf /var/lib/apt/lists/*

COPY --from=frontend /usr/local/bin/node /usr/local/bin/node
COPY --from=frontend /usr/local/lib/node_modules/npm /usr/local/lib/node_modules/npm
COPY --from=frontend /usr/local/lib/node_modules/corepack /usr/local/lib/node_modules/corepack
RUN ln -sf /usr/local/lib/node_modules/npm/bin/npm-cli.js /usr/local/bin/npm && \
    ln -sf /usr/local/lib/node_modules/npm/bin/npx-cli.js /usr/local/bin/npx && \
    ln -sf /usr/local/lib/node_modules/corepack/dist/corepack.js /usr/local/bin/corepack

WORKDIR /app

COPY . .
COPY --from=frontend /app/node_modules ./node_modules
COPY --from=frontend /app/hermes-web-ui/node_modules ./hermes-web-ui/node_modules
COPY --from=frontend /app/hermes_cli/web_dist ./hermes_cli/web_dist

RUN touch README.md && \
    python -m venv /app/.venv && \
    /app/.venv/bin/pip install --no-cache-dir --upgrade pip setuptools wheel && \
    /app/.venv/bin/pip install --no-cache-dir -e ".[messaging,matrix,anthropic,bedrock,azure-identity]"

RUN useradd -u 10000 -m -d /opt/data hermes && \
    mkdir -p /opt/data && \
    chown -R hermes:hermes /opt/data /app

USER hermes

EXPOSE 9119
VOLUME ["/opt/data"]

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
  CMD curl -fsS http://127.0.0.1:9119/api/auth/status >/dev/null || exit 1

CMD ["python", "-m", "hermes_cli.main", "dashboard", "--host", "0.0.0.0", "--port", "9119", "--no-open", "--skip-build"]
